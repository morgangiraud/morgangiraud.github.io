{
  "name": "morgangiraud.github.io",
  "description": "Personal website of Morgan Giraud",
  "repository": "git@github.com:morgangiraud/morgangiraud.github.io.git",
  "author": "Morgan Giraud",
  "license": "MIT",
  "scripts": {
    "build": "yarn build:css && yarn minify:css && yarn build:cv",
    "build:css": "tailwindcss -i src/main.css -o ./public/styles.css",
    "build:cv": "node src/cv/render.js",
    "check:js:node": "node --check src/cv/render.js",
    "check:js:inline": "node src/scripts/check-inline-scripts.js",
    "check:runtime:cv": "node --unhandled-rejections=strict src/cv/render.js",
    "watch": "tailwindcss -i src/main.css -o ./public/styles.css --watch",
    "minify:css": "postcss ./public/styles.css -o ./public/styles.min.css",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "browserslist": "^4.26.0",
    "cssnano": "^7.1.2",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.2.1",
    "update-browserslist-db": "^1.2.3"
  },
  "devDependencies": {
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "markdown-it-container": "^4.0.0",
    "mustache": "^4.2.0",
    "npm-check-updates": "^19.6.3",
    "prettier": "^3.8.1"
  }
}
